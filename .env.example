# EnvEditor — environment variables
# Copy this file to .env and fill in the values

# Required: bearer token for all API routes
# Generate a strong token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EDITOR_TOKEN=

# Optional: port to listen on (default: 4200)
PORT=4200

# Optional: GitHub webhook secret for auto-deploy (must match GitHub webhook config)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# Optional: override .env file paths per container name
# JSON object mapping container name to absolute path inside the container
# Example: {"n8n":"/data/.env","my-app":"/home/app/.env"}
ENV_PATHS_OVERRIDE={}
